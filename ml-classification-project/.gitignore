# =============================================================================
# Python .gitignore for ML Projects
# =============================================================================

# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------------------------------------------------------
# C extensions
# -----------------------------------------------------------------------------
*.so

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/
.env.local

# -----------------------------------------------------------------------------
# IDE / Editor settings
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Environment variables (IMPORTANT: Never commit secrets!)
# -----------------------------------------------------------------------------
.env
.env.production
.env.staging
*.env
secrets.yaml
secrets.json

# -----------------------------------------------------------------------------
# ML specific
# -----------------------------------------------------------------------------
# Large model files (use Git LFS or DVC instead)
*.h5
*.hdf5
*.pkl
*.pickle
# Keep joblib models tracked for this learning project
# *.joblib

# Data files (often too large for git)
data/raw/*.csv
data/processed/
*.parquet
*.feather

# MLflow
mlruns/
mlartifacts/

# Weights & Biases
wandb/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Generated documentation
# -----------------------------------------------------------------------------
docs/_build/
site/
