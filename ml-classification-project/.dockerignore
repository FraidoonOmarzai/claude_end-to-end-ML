# =============================================================================
# Docker Ignore File
# =============================================================================
#
# STUDY NOTE: .dockerignore
# -------------------------
# Similar to .gitignore, but for Docker builds.
# Files listed here are NOT sent to the Docker daemon during build.
#
# Benefits:
# - Faster builds (less data to transfer)
# - Smaller images (don't accidentally include junk)
# - Security (don't include secrets)
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv
venv
ENV
env
.eggs
*.egg-info
*.egg
.mypy_cache
.pytest_cache
.coverage
htmlcov
.tox
.nox

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.*

# -----------------------------------------------------------------------------
# Documentation & Misc
# -----------------------------------------------------------------------------
*.md
!README.md
docs/
*.log
logs/

# -----------------------------------------------------------------------------
# Docker (don't include Docker files in build context recursively)
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test_*
*_test.py

# -----------------------------------------------------------------------------
# Development files
# -----------------------------------------------------------------------------
Makefile
.pre-commit-config.yaml
pyproject.toml
requirements-dev.txt

# -----------------------------------------------------------------------------
# Data files (often too large)
# -----------------------------------------------------------------------------
data/
*.csv
*.parquet
notebooks/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
